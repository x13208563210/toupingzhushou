{
  "name": "live-cast-desktop-console",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "build": "vite build",
    "start": "electron ."
  },
  "dependencies": {
    "cnchar": "^3.2.6",
    "liquid-glass-react": "^1.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "vite": "^7.1.12",
    "wait-on": "^8.0.5"
  }
}
